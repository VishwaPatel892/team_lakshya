{
  "manifest_version": 3,
  "name": "LAKSHYA - AI Browser Companion",
  "version": "1.0.0",
  "description": "An intelligent browser companion that extracts webpage content, reads it aloud, and answers questions with context.",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel",
    "scripting",
    "audioCapture"
  ],
  "host_permissions": [
    "http://localhost:5000/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open LAKSHYA Companion",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "index.html",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
